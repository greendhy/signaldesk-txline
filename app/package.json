{
  "name": "signaldesk-txline-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "concurrently -k \"tsx watch src/server.ts\" \"vite --host 127.0.0.1\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "start": "tsx src/server.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test src/shared/engine.test.ts",
    "audit:replay": "tsx scripts/audit-verified-replay.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "buffer": "^6.0.3",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
